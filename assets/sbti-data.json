  "type_library": {
    "CTRL": { "code": "CTRL", "cn": "拿捏者", "intro": "怎么样，被我拿捏了吧？", "desc": "规则感、推进力和掌控感都很强，像一台会自己开会的人形任务管理器。" },
    "ATM-er": { "code": "ATM-er", "cn": "送钱者", "intro": "你以为我很有钱吗？", "desc": "极度可靠，容易为别人持续支付时间、精力和责任感。" },
    "Dior-s": { "code": "Dior-s", "cn": "屌丝", "intro": "等着我屌丝逆袭。", "desc": "看穿成功学滤镜，更在意舒服、真实和对宏大叙事的嘲讽。" },
    "BOSS": { "code": "BOSS", "cn": "领导者", "intro": "方向盘给我，我来开。", "desc": "天然接管局面，目标感、效率和向上驱动都偏强。" },
    "THAN-K": { "code": "THAN-K", "cn": "感恩者", "intro": "我感谢苍天！我感谢大地！", "desc": "更愿意从世界里提取善意和解释空间，正向意义感很强。" },
    "OH-NO": { "code": "OH-NO", "cn": "哦不人", "intro": "哦不！我怎么会是这个人格？！", "desc": "风险警报器灵敏，边界强，凡事先替未来的灾难踩刹车。" },
    "GOGO": { "code": "GOGO", "cn": "行者", "intro": "gogogo~出发咯", "desc": "对行动有天然偏好，不爱把事情悬着，更相信做了再说。" },
    "SEXY": { "code": "SEXY", "cn": "尤物", "intro": "您就是天生的尤物！", "desc": "存在感强，表达风格鲜明，容易在人群里形成高注意力场。" },
    "LOVE-R": { "code": "LOVE-R", "cn": "多情者", "intro": "爱意太满，现实显得有点贫瘠。", "desc": "情感投入度高，亲密关系里容易认真、理想化，也更愿意梭哈真心。" },
    "MUM": { "code": "MUM", "cn": "妈妈", "intro": "或许...我可以叫你妈妈吗....?", "desc": "共情力强，照顾人、疗愈人，但也常把对自己的温柔打折。" },
    "FAKE": { "code": "FAKE", "cn": "伪人", "intro": "已经，没有人类了。", "desc": "对场景切换很熟练，擅长根据人际环境调整自己的表达层。" },
    "OJBK": { "code": "OJBK", "cn": "无所谓人", "intro": "我说随便，是真的随便。", "desc": "对很多外部选择并不执着，松弛、旁观，也不爱卷进无谓争论。" },
    "MALO": { "code": "MALO", "cn": "吗喽", "intro": "人生是个副本，而我只是一只吗喽。", "desc": "玩心、自由度和不按牌理出牌的倾向很强，讨厌无聊秩序。" },
    "JOKE-R": { "code": "JOKE-R", "cn": "小丑", "intro": "原来我们都是小丑。", "desc": "用幽默和玩笑维持社交热度，也常把真实情绪藏在段子后面。" },
    "WOC!": { "code": "WOC!", "cn": "握草人", "intro": "卧槽，我怎么是这个人格？", "desc": "表面反应很大，内里其实经常已经完成冷静判断。" },
    "THIN-K": { "code": "THIN-K", "cn": "思考者", "intro": "已深度思考100s。", "desc": "偏理性与审慎，擅长拆逻辑、做判断，也比较捍卫个人边界。" },
    "SHIT": { "code": "SHIT", "cn": "愤世者", "intro": "这个世界，构石一坨。", "desc": "嘴上吐槽世界，手上仍然会把烂摊子认真收拾好。" },
    "ZZZZ": { "code": "ZZZZ", "cn": "装死者", "intro": "我没死，我只是在睡觉。", "desc": "低功耗待机、死线觉醒型，很多事情拖到最后一刻才全面启动。" },
    "POOR": { "code": "POOR", "cn": "贫困者", "intro": "我穷，但我很专。", "desc": "不把资源撒出去，更愿意专注在少数重要目标上狠狠干到底。" },
    "MONK": { "code": "MONK", "cn": "僧人", "intro": "没有那种世俗的欲望。", "desc": "空间感和独处需求强，不喜欢被过度侵入，也不爱高频纠缠。" },
    "IMSB": { "code": "IMSB", "cn": "傻者", "intro": "认真的么？我真的是傻逼么？", "desc": "冲动与自我否定经常同时在线，内心戏比表面状态丰富得多。" },
    "SOLO": { "code": "SOLO", "cn": "孤儿", "intro": "我哭了，我怎么会是孤儿？", "desc": "对关系有渴望，也有防御，常在靠近和后退之间来回拉扯。" },
    "FUCK": { "code": "FUCK", "cn": "草者", "intro": "操！这是什么人格？", "desc": "生命力强、冲劲足，不太服从世俗规训，更愿意按本能和爽感活。" },
    "DEAD": { "code": "DEAD", "cn": "死者", "intro": "我，还活着吗？", "desc": "意义感和驱动力都偏低，对很多宏大目标保持冷淡甚至抽离。" },
